# ─── App ──────────────────────────────────────────────────────────────────────
VITE_APP_NAME="ROKE Industries Hosting"

# ─── API ──────────────────────────────────────────────────────────────────────
# Dev:     http://localhost:8000/api
# Staging: https://api.staging.rokeindustries.com/api
# Prod:    https://api.rokeindustries.com/api
VITE_API_URL=http://localhost:8000/api

# ─── Dev server ───────────────────────────────────────────────────────────────
VITE_DEV_PORT=5173
VITE_PREVIEW_PORT=4173
# Hosts adicionales permitidos (separados por coma). Dejar vacío en dev local.
# VITE_ALLOWED_HOSTS=staging.rokeindustries.com,app.rokeindustries.com

# ─── Google OAuth ─────────────────────────────────────────────────────────────
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ─── Stripe ───────────────────────────────────────────────────────────────────
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# ─── Laravel Reverb (WebSockets) ──────────────────────────────────────────────
VITE_REVERB_APP_KEY=your-reverb-app-key
VITE_REVERB_HOST=localhost
VITE_REVERB_PORT=8080
VITE_REVERB_SCHEME=http
